      "label": "Crisis Resources — Veterans Crisis Line and 6-step Safety Plan"
    }
  ],

  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.bigsarge.unseenmarch",
      "id": "com.bigsarge.unseenmarch"
    }
  ],

  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",

  "scope_extensions": [
    {
      "origin": "https://wayneaince-sys.github.io"
    },
    {
      "origin": "https://big-sarge.blog"
    }
  ],

  "edge_side_panel": {
    "preferred_width": 430
  }
}
