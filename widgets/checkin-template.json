{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "🪖 Unseen March",
      "size": "Small",
      "weight": "Bolder",
      "color": "Accent"
    },
    {
      "type": "TextBlock",
      "text": "\"${quote}\"",
      "wrap": true,
      "size": "Small",
      "isSubtle": true,
      "fontType": "Monospace"
    },
    {
      "type": "TextBlock",
      "text": "— ${quoteSource}",
      "size": "ExtraSmall",
      "isSubtle": true
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "🔥 ${streak}-day streak",
              "size": "Small",
              "weight": "Bolder"
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "How are you feeling?",
      "size": "Small",
      "weight": "Bolder",
      "spacing": "Small"
    },
    {
      "type": "ActionSet",
      "actions": [
        { "type": "Action.OpenUrl", "title": "😔", "url": "${appUrl}&mood=1" },
        { "type": "Action.OpenUrl", "title": "😐", "url": "${appUrl}&mood=3" },
        { "type": "Action.OpenUrl", "title": "💪", "url": "${appUrl}&mood=5" }
      ]
    }
  ],
  "actions": [
    { "type": "Action.OpenUrl", "title": "Open App", "url": "/unseen-march-pwa/" }
  ]
}
